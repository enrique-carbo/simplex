---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import Button from '~/components/ui/Button.astro';

import { getHomePermalink } from '~/utils/permalinks';
import { trimSlash } from '~/utils/permalinks';

const { isLoggedIn = false, user = null } = Astro.locals;
const userId = user?.id ?? null;

// import CarritoNanostore from '@/components/shadcn/CarritoNanostore';
import CarritoNanostorePocketbase from '../shadcn/CarritoNanostorePocketbase';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface MenuLink extends Link {
  links?: Array<MenuLink>;
}

export interface Props {
  id?: string;
  links?: Array<MenuLink>;
  isSticky?: boolean;
  isDark?: boolean;
  isFullWidth?: boolean;
  showToggleTheme?: boolean;
  showRssFeed?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  isSticky = false,
  isDark = false,
  isFullWidth = false,
  position = 'center',
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky, dark: isDark },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-50/0 transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div
    class="absolute inset-0 bg-white dark:bg-dark border-b border-gray-200 dark:border-slate-800 backdrop-blur-md bg-opacity-90 dark:bg-opacity-90"
  >
  </div>
  <div
    class:list={[
      'relative text-default py-3 px-3 md:px-6 mx-auto w-full',
      {
        'md:flex md:justify-between': position !== 'center',
      },
      {
        'md:grid md:grid-cols-3 md:items-center': position === 'center',
      },
      {
        'max-w-7xl': !isFullWidth,
      },
    ]}
  >
    <div class:list={[{ 'mr-auto rtl:mr-0 rtl:ml-auto': position === 'right' }, 'flex justify-between']}>
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class:list={[
        'items-center w-full md:w-auto hidden md:flex md:mx-5 text-default md:justify-self-center',
        // Estilos para Móvil (cuando el botón le quita el 'hidden')
        'absolute md:static top-full left-0 right-0 z-50',
        'bg-white dark:bg-dark shadow-xl md:shadow-none',
        'max-h-[80vh] overflow-y-auto overflow-x-hidden', // <-- El scroll mágico
        // Reset para Escritorio
        'md:max-h-none md:overflow-visible md:bg-transparent',
      ]}
      aria-label="Main navigation"
    >
      <ul
        class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-[0.9375rem] tracking-[0.01rem] font-medium md:justify-center"
      >
        {
          links.map(({ text, href, links }) => (
            <li class={links?.length ? 'dropdown' : ''}>
              {links?.length ? (
                <>
                  <button type="button" class="hover:text-link dark:hover:text-white px-4 py-3 flex items-center">
                    {text}{' '}
                    <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 rtl:ml-0 rtl:mr-0.5 hidden md:inline" />
                  </button>
                  <ul class="dropdown-menu md:backdrop-blur-md dark:md:bg-dark rounded md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white/90 md:min-w-[200px] drop-shadow-xl">
                    {links.map(({ text: text2, href: href2 }) => (
                      <li>
                        <a
                          class:list={[
                            'first:rounded-t last:rounded-b md:hover:bg-gray-100 hover:text-link dark:hover:text-white dark:hover:bg-gray-700 py-2 px-5 block whitespace-no-wrap',
                            { 'aw-link-active': href2 === currentPath },
                          ]}
                          href={href2}
                        >
                          {text2}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a
                  class:list={[
                    'hover:text-link dark:hover:text-white px-4 py-3 flex items-center',
                    { 'aw-link-active': href === currentPath },
                  ]}
                  href={href}
                >
                  {text}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
    <div
      class:list={[
        { 'ml-auto rtl:ml-0 rtl:mr-auto': position === 'left' },
        // CAMBIO: Quitamos el 'hidden' y usamos flex-col para móvil, row para PC
        'flex flex-col md:flex-row md:self-center items-center md:mb-0 w-full md:w-auto p-3 md:p-0 justify-end',
        'border-t border-gray-100 dark:border-gray-800 md:border-none', // Separador sutil
      ]}
    >
      <div class="items-center flex justify-between w-full md:w-auto gap-4">
        <div class="flex items-center">
          <CarritoNanostorePocketbase client:only="react" userId={userId} isLoggedIn={isLoggedIn} />
        </div>

        <div class="flex items-center">
          {
            isLoggedIn ? (
              <a href="/dashboard" class="...">
                <Icon name="tabler:user-circle" class="w-6 h-6 text-primary inline" />
                <span>Mi Cuenta</span>
              </a>
            ) : (
              <Button href="/auth/login" variant="primary" class="w-min md:w-auto">
                Ingresar
              </Button>
            )
          }
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const onHeaderClick = (event: Event) => {
    const target = event.target as HTMLElement;

    // 1. Manejo del Toggle Menu (Hamburguesa)
    const toggleButton = target?.closest('[data-aw-toggle-menu]');
    if (toggleButton) {
      const nav = toggleButton.closest('header')?.querySelector('nav');
      if (nav) {
        toggleButton.classList.toggle('expanded');
        nav.classList.toggle('hidden');
        document.body.classList.toggle('overflow-hidden');
      }
      return; // Salimos para no ejecutar lo de abajo si tocamos el toggle
    }

    // 2. Manejo de Dropdowns (Productos)
    const dropdownButton = target?.closest('li.dropdown > button');
    if (dropdownButton) {
      const menu = dropdownButton.parentElement?.querySelector('.dropdown-menu');
      if (menu) {
        // Alternamos la visibilidad del submenú
        menu.classList.toggle('md:hidden');

        // Cerramos otros dropdowns si hubiera más de uno
        document.querySelectorAll('.dropdown-menu').forEach((m) => {
          if (m !== menu) m.classList.add('md:hidden');
        });
      }
    } else {
      // 3. Cerrar dropdowns si se toca en cualquier otro lado de la pantalla
      if (!target.closest('li.dropdown')) {
        document.querySelectorAll('.dropdown-menu').forEach((m) => m.classList.add('md:hidden'));
      }
    }
  };

  const setupHeader = () => {
    document.removeEventListener('click', onHeaderClick);
    document.addEventListener('click', onHeaderClick);
  };

  // Ciclo de vida completo para Local y Cloudflare
  setupHeader();
  document.addEventListener('astro:page-load', setupHeader);
  document.addEventListener('astro:after-swap', setupHeader);
</script>
